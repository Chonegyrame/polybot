# Polymarket APIs (no auth needed for reads — these are documented base URLs only)
GAMMA_API_BASE=https://gamma-api.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
# (lb-api.polymarket.com is the legacy leaderboard service — no longer used. The
# proper endpoint is data-api.polymarket.com/v1/leaderboard with full pagination.)

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Direct Postgres connection string (asyncpg uses this — find in Supabase
# Project Settings -> Database -> Connection string -> URI). Use the
# pooler/transaction string for serverless workloads, direct for long-running.
DATABASE_URL=

# Resend (email alerts)
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# App config
LOG_LEVEL=INFO
RATE_LIMIT_PER_SECOND=10
